# Copy to .env and fill in. Never commit the real .env.

# --- Required ---
# Google AI Studio key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# --- Optional ---
# Database. Default uses an aiosqlite file next to the project.
DATABASE_URL=sqlite+aiosqlite:///./agentic_sdlc.db

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Gemini model. Choose what your API key has access to (call
# https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY to list).
# Sensible defaults:
#   gemini-2.5-flash       — recommended; newest stable Flash
#   gemini-2.5-flash-lite  — cheaper / lighter quota
#   gemini-flash-latest    — auto-tracks latest stable Flash
GEMINI_MODEL=gemini-2.5-flash

# Optional research tool API key (Tavily free tier)
TAVILY_API_KEY=

# Optional shared API key gating /api/* and /ws/*. Leave blank for open dev
# access; set to a long random string for any shared/deployed instance.
API_KEY=

# CORS origins (comma-separated). Empty = allow none.
CORS_ORIGINS=http://localhost:3000
